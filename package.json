{
  "name": "sopla-el-cartucho-en-jueves-de-quack",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Jueves de Quack retro site — Astro UI + Game Boy cartridges for GitHub YouTube sessions",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "astro dev --host",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --test test/*.test.js",
    "fetch-sessions": "tsx scripts/fetch-sessions.ts",
    "generate:assets": "tsx scripts/generate-assets.ts",
    "generate:covers": "tsx scripts/generate-covers.ts",
    "generate:all": "npm run generate:assets && npm run generate:covers"
  },
  "dependencies": {
    "sharp": "^0.34.5",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/parser": "^8.59.1",
    "astro": "^6.1.10",
    "eslint": "^10.2.1",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "^8.5.12",
    "devalue": "^5.6.4"
  }
}
