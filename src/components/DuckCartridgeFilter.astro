---
/*
 * Duck cartridge separator/filter for month grouping
 * Inspired by CartridgeCard.astro (Game Boy cartridge design by Van Huynh)
 * https://codepen.io/worksbyvan/pen/MoxroE — MIT License
 */

type Props = {
  month: string; // e.g. "Marzo"
  year: string; // e.g. "2026"
  monthKey: string; // e.g. "2026-03" used as filter key
};

const { month, year, monthKey } = Astro.props;
---

<button
  class="duck-filter-wrap"
  data-month-key={monthKey}
  aria-label={`Filtrar sesiones de ${month} ${year}`}
  title={`Ver solo sesiones de ${month} ${year}`}
>
  <div class="duck-cartridge">
    <div class="duck-case">
      <!-- Front face -->
      <div class="duck-front">
        <div class="duck-base tall"></div>
        <div class="duck-base wide"></div>
        <div class="duck-linebase"></div>
        <div class="duck-line one"></div>
        <div class="duck-line two"></div>
        <div class="duck-line three"></div>
        <div class="duck-line four"></div>
        <div class="duck-leftindent"></div>
        <div class="duck-rightindent"></div>
        <div class="duck-oval"></div>
        <div class="duck-label">
          <div class="duck-sprite" aria-hidden="true">
            <!-- Pixel duck (8×8 grid) -->
            <svg
              viewBox="0 0 8 8"
              width="40"
              height="40"
              xmlns="http://www.w3.org/2000/svg"
              style="image-rendering:pixelated"
              aria-hidden="true"
            >
              <!-- body -->
              <rect x="1" y="4" width="5" height="3" fill="#f5d060"></rect>
              <!-- head -->
              <rect x="4" y="2" width="3" height="3" fill="#f5d060"></rect>
              <!-- beak -->
              <rect x="6" y="3" width="2" height="1" fill="#e07020"></rect>
              <!-- eye -->
              <rect x="5" y="2" width="1" height="1" fill="#1a1a1a"></rect>
              <!-- wing -->
              <rect x="2" y="5" width="2" height="1" fill="#d4a820"></rect>
              <!-- tail -->
              <rect x="1" y="4" width="1" height="1" fill="#d4a820"></rect>
              <!-- water ripple -->
              <rect x="0" y="7" width="8" height="1" fill="#3a8fd4" opacity="0.5"></rect>
            </svg>
          </div>
          <div class="duck-month-label">
            <span class="duck-icon-quack">🐤</span>
            <span class="duck-month">{month}</span>
            <span class="duck-year">{year}</span>
          </div>
          <div class="duck-filter-hint">CLICK PARA FILTRAR</div>
        </div>
      </div>

      <!-- Back face -->
      <div class="duck-back">
        <div class="duck-base tall"></div>
        <div class="duck-base wide"></div>
        <div class="duck-line one"></div>
        <div class="duck-line two"></div>
        <div class="duck-line three"></div>
        <div class="duck-line four"></div>
      </div>

      <!-- Right side -->
      <div class="duck-rightside">
        <div class="top"></div>
        <div class="bottom"></div>
        <div class="duck-line one"></div>
        <div class="ceiling one"></div>
        <div class="floor one"></div>
        <div class="duck-line two"></div>
        <div class="ceiling two"></div>
        <div class="floor two"></div>
        <div class="duck-line three"></div>
        <div class="ceiling three"></div>
        <div class="floor three"></div>
        <div class="duck-line four"></div>
        <div class="ceiling four"></div>
        <div class="floor four"></div>
      </div>

      <!-- Left side -->
      <div class="duck-leftside">
        <div class="bottom"></div>
        <div class="duck-line one"></div>
        <div class="ceiling one"></div>
        <div class="floor one"></div>
        <div class="duck-line two"></div>
        <div class="ceiling two"></div>
        <div class="floor two"></div>
        <div class="duck-line three"></div>
        <div class="ceiling three"></div>
        <div class="floor three"></div>
        <div class="duck-line four"></div>
        <div class="ceiling four"></div>
        <div class="floor four"></div>
      </div>

      <!-- Top side -->
      <div class="duck-topside">
        <div class="left"></div>
        <div class="right"></div>
      </div>

      <!-- Bottom side (connector edge) -->
      <div class="duck-bottomside">
        <div class="side"></div>
      </div>
    </div>
  </div>
</button>

<style>
  /* ── Dimensions & duck palette ─────────────────── */
  .duck-filter-wrap {
    --cw: 196px;
    --ch: 225px;
    --cd: 20px;
    --cd2: 10px;

    /* Duck yellow/amber palette */
    --c-base: #c8960a;
    --c-dark: #a87a06;
    --c-darker: #8a6204;
    --c-label-bg: #1a2a10;

    /* Reset button defaults */
    appearance: none;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font: inherit;
    color: inherit;

    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 300px;
    padding: 24px 36px;
    transition:
      transform 0.2s ease,
      filter 0.2s ease;
  }

  .duck-filter-wrap:hover {
    transform: translateY(-4px) scale(1.02);
  }

  .duck-filter-wrap.is-active {
    transform: translateY(-8px) scale(1.05);
    filter: drop-shadow(0 8px 20px rgba(240, 200, 40, 0.6));
  }

  .duck-filter-wrap.is-active::after {
    content: '▶ FILTRANDO';
    position: absolute;
    bottom: -24px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-display);
    font-size: 8px;
    color: #f5d060;
    background: #2a1e0e;
    padding: 4px 8px;
    border-radius: 4px;
    white-space: nowrap;
  }

  /* ── Cartridge container ──────────────────────────── */
  .duck-cartridge {
    position: relative;
    display: inline-block;
    width: var(--cw);
    height: var(--ch);
    perspective: 900px;
    transform-style: preserve-3d;
    flex-shrink: 0;
  }

  .duck-case {
    position: absolute;
    height: 100%;
    width: 100%;
    transform-style: preserve-3d;
    transform: rotateY(-22deg) rotateX(10deg);
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .duck-filter-wrap:hover .duck-case {
    transform: rotateY(-8deg) rotateX(4deg);
  }

  /* ── Front / Back ─────────────────────────────────── */
  .duck-front,
  .duck-back {
    display: block;
    position: absolute;
    height: 100%;
    width: 100%;
  }

  .duck-front .duck-base,
  .duck-back .duck-base {
    background-color: var(--c-base);
    position: absolute;
  }

  .duck-front .tall,
  .duck-back .tall {
    height: 50%;
    width: 90%;
    top: 0;
    left: 0;
  }

  .duck-front .wide,
  .duck-back .wide {
    height: 95%;
    width: 100%;
    bottom: 0;
    right: 0;
  }

  .duck-linebase {
    position: absolute;
    background-color: var(--c-dark);
    width: 100%;
    height: 15%;
    top: 9%;
    left: 0;
  }

  .duck-front .duck-line,
  .duck-back .duck-line {
    position: absolute;
    background-color: var(--c-base);
    width: 104%;
    left: -2%;
    height: calc(15% / 9);
  }

  .duck-leftindent,
  .duck-rightindent {
    position: absolute;
    height: 65%;
    width: 2%;
    bottom: 0;
    background-color: var(--c-dark);
  }

  .duck-rightindent {
    right: 0;
  }

  .duck-oval {
    position: absolute;
    width: 75%;
    height: 15%;
    background-color: var(--c-dark);
    border: calc(var(--cw) / 50) solid var(--c-base);
    border-radius: 9999px;
    left: calc(12.5% - 2%);
    top: 7%;
  }

  /* ── Duck label ──────────────────────────────────── */
  .duck-front .duck-label {
    position: absolute;
    height: calc(var(--cw) * 0.75);
    width: 70%;
    bottom: 7%;
    left: calc(15% - 1%);
    border: calc(var(--cw) / 100) solid rgba(0, 0, 0, 0.4);
    border-radius: calc(var(--cw) / 50);
    overflow: hidden;
    padding: 8px 6px 6px;
    background: linear-gradient(160deg, #2a3a10 0%, #1a2808 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    gap: 4px;
  }

  .duck-sprite {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .duck-month-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    flex: 1;
    justify-content: center;
  }

  .duck-icon-quack {
    font-size: 1rem;
    line-height: 1;
  }

  .duck-month {
    font-family: var(--font-display);
    font-size: 0.42rem;
    color: #f5d060;
    text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.6);
    text-align: center;
    line-height: 1.4;
    letter-spacing: 0.04em;
  }

  .duck-year {
    font-family: var(--font-display);
    font-size: 0.38rem;
    color: #c8f080;
    text-align: center;
    line-height: 1.2;
  }

  .duck-filter-hint {
    font-family: var(--font-display);
    font-size: 0.3rem;
    color: #8ab860;
    text-align: center;
    padding: 2px 4px;
    border: 1px solid #4a6830;
    background: rgba(0, 0, 0, 0.3);
    line-height: 1.3;
    letter-spacing: 0.02em;
  }

  /* ── translateZ for front/back ────────────────────── */
  .duck-front {
    transform: translateZ(var(--cd2));
  }

  .duck-back {
    transform: translateZ(calc(-1 * var(--cd2)));
  }

  /* ── Groove line positions ────────────────────────── */
  .one {
    top: calc(9% + (15% / 9) * 1);
  }
  .two {
    top: calc(9% + (15% / 9) * 3);
  }
  .three {
    top: calc(9% + (15% / 9) * 5);
  }
  .four {
    top: calc(9% + (15% / 9) * 7);
  }

  /* ── Right / Left sides ───────────────────────────── */
  .duck-rightside,
  .duck-leftside {
    position: absolute;
    width: var(--cd);
    height: 100%;
    bottom: 0;
    transform-style: preserve-3d;
    transform: rotateY(90deg);
  }

  .duck-rightside {
    right: calc(-1 * var(--cd2));
  }

  .duck-leftside {
    left: calc(-1 * var(--cd2));
  }

  .duck-rightside .top {
    position: absolute;
    background-color: var(--c-darker);
    width: 100%;
    height: 5%;
    transform: translateZ(calc(-1 * var(--cd)));
  }

  .duck-rightside .bottom,
  .duck-leftside .bottom {
    position: absolute;
    bottom: 0;
    background-color: var(--c-dark);
    width: 100%;
  }

  .duck-rightside .bottom {
    height: 95%;
  }
  .duck-leftside .bottom {
    height: 100%;
  }

  .duck-rightside .duck-line,
  .duck-leftside .duck-line {
    position: absolute;
    background-color: var(--c-darker);
    height: calc(15% / 9);
    width: 100%;
  }

  .duck-rightside .duck-line {
    transform: translateZ(calc(var(--cw) * 0.02));
  }
  .duck-leftside .duck-line {
    transform: translateZ(calc(-1 * var(--cw) * 0.02));
  }

  .duck-rightside .floor,
  .duck-rightside .ceiling,
  .duck-leftside .floor,
  .duck-leftside .ceiling {
    position: absolute;
    background-color: var(--c-dark);
    width: 100%;
    height: calc(var(--cw) * 0.04);
    transform: rotateX(90deg);
  }

  .duck-rightside .ceiling,
  .duck-leftside .ceiling {
    transform: translateY(calc(-1 * var(--ch) * 0.15 / 9)) rotateX(90deg);
  }

  /* ── Top side ─────────────────────────────────────── */
  .duck-topside {
    position: absolute;
    width: 100%;
    height: var(--cd);
    top: calc(-1 * var(--cd2));
    transform: rotateX(90deg);
    transform-style: preserve-3d;
  }

  .duck-topside .left {
    position: absolute;
    background-color: var(--c-dark);
    width: 90%;
    height: 100%;
  }

  .duck-topside .right {
    position: absolute;
    background-color: var(--c-darker);
    width: 10%;
    height: 100%;
    right: 0;
    transform: translateZ(calc(-1 * var(--ch) * 0.05));
  }

  /* ── Bottom side (connector edge) ────────────────── */
  .duck-bottomside {
    position: absolute;
    background-color: #1e1e1e;
    bottom: calc(-1 * var(--cd2));
    height: calc(var(--cd) / 2);
    width: calc(var(--cw) - var(--cd2));
    transform: rotateX(90deg);
    border: calc(var(--cw) * 0.025) solid var(--c-darker);
  }
</style>
