---
type Props = {
  currentPage?: string;
};

const { currentPage = 'home' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const links = [
  { id: 'home', label: 'SESIONES', href: `${base}/` },
  { id: 'player1', label: 'SOBRE MI', href: `${base}/player1/` },
  { id: 'demos', label: 'RECURSOS', href: `${base}/demos/` },
];
---

<nav class="main-nav" aria-label="Primary">
  {
    links.map((link) => (
      <a
        href={link.href}
        class:list={['main-nav-link', { active: currentPage === link.id }]}
        aria-current={currentPage === link.id ? 'page' : undefined}
      >
        {link.label}
      </a>
    ))
  }
  <button
    id="theme-toggle"
    class="main-nav-link theme-toggle"
    aria-label="Cambiar tema claro/oscuro"
    title="Cambiar tema"
  >
    <span class="icon-dark" aria-hidden="true">🌙</span>
    <span class="icon-light" aria-hidden="true">☀️</span>
  </button>
</nav>

<script>
  function initThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;

    btn.addEventListener('click', () => {
      const html = document.documentElement;
      const isDark = html.dataset.theme === 'dark';
      const next = isDark ? 'light' : 'dark';
      html.dataset.theme = next;
      localStorage.setItem('theme', next);
    });
  }

  // Funciona en navegación con y sin recargas
  initThemeToggle();
  document.addEventListener('astro:page-load', initThemeToggle);
</script>

<style>
  .main-nav {
    display: flex;
    gap: 6px;
    padding: 8px 0 0;
  }

  .main-nav-link {
    display: inline-block;
    background: linear-gradient(180deg, #f8c84a, #d48c20);
    border: 3px solid var(--border-strong);
    box-shadow:
      3px 3px 0 rgba(50, 35, 14, 0.6),
      inset 0 1px 0 rgba(255, 245, 180, 0.5);
    padding: 6px 14px;
    text-align: center;
    font-family: var(--font-display);
    font-size: 0.65rem;
    color: #1e140a;
    text-decoration: none;
    transition:
      transform 0.1s,
      box-shadow 0.1s;
  }

  .main-nav-link:hover {
    background: linear-gradient(180deg, #ffd85a, #e09a28);
    box-shadow:
      2px 2px 0 rgba(50, 35, 14, 0.6),
      inset 0 1px 0 rgba(255, 245, 180, 0.5);
    transform: translate(1px, 1px);
  }

  .main-nav-link.active {
    background: linear-gradient(180deg, #b87818, #8a5810);
    box-shadow:
      inset 2px 2px 0 rgba(50, 35, 14, 0.5),
      inset -1px -1px 0 rgba(255, 245, 180, 0.15);
    transform: translate(2px, 2px);
    color: #f5e0b0;
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.4);
  }

  .theme-toggle {
    cursor: pointer;
    margin-left: auto;
    border: 3px solid var(--border-strong);
    font-size: 0.85rem;
    line-height: 1;
    padding: 4px 10px;
  }

  .theme-toggle .icon-light {
    display: none;
  }

  :global([data-theme='dark']) .theme-toggle .icon-dark {
    display: none;
  }

  :global([data-theme='dark']) .theme-toggle .icon-light {
    display: inline;
  }
</style>
