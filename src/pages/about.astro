---
import BaseLayout from '../layouts/BaseLayout.astro';

const features = [
  { name: 'COMUNIDAD', value: 95 },
  { name: 'GITHUB', value: 100 },
  { name: 'AI', value: 90 },
  { name: 'DEVOPS', value: 85 },
  { name: 'LIVE', value: 90 },
];

const socials = [
  { label: 'YOUTUBE', href: 'https://www.youtube.com/@GitHub', svg: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><path fill="currentColor" d="m10 15l5.19-3L10 9zm11.56-7.83c.13.47.22 1.1.28 1.9c.07.8.1 1.49.1 2.09L22 12c0 2.19-.16 3.8-.44 4.83c-.25.9-.83 1.48-1.73 1.73c-.47.13-1.33.22-2.65.28c-1.3.07-2.49.1-3.59.1L12 19c-4.19 0-6.8-.16-7.83-.44c-.9-.25-1.48-.83-1.73-1.73c-.13-.47-.22-1.1-.28-1.9c-.07-.8-.1-1.49-.1-2.09L2 12c0-2.19.16-3.8.44-4.83c.25-.9.83-1.48 1.73-1.73c.47-.13 1.33-.22 2.65-.28c1.3-.07 2.49-.1 3.59-.1L12 5c4.19 0 6.8.16 7.83.44c.9.25 1.48.83 1.73 1.73"/></svg>' },
  { label: 'GITHUB', href: 'https://github.com/githubevents/jueves-de-quack', svg: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2"/></svg>' },
  { label: 'X', href: 'https://x.com/github', svg: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><path fill="currentColor" d="M22.46 6c-.77.35-1.6.58-2.46.69c.88-.53 1.56-1.37 1.88-2.38c-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29c0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15c0 1.49.75 2.81 1.91 3.56c-.71 0-1.37-.2-1.95-.5v.03c0 2.08 1.48 3.82 3.44 4.21a4.2 4.2 0 0 1-1.93.07a4.28 4.28 0 0 0 4 2.98a8.52 8.52 0 0 1-5.33 1.84q-.51 0-1.02-.06C3.44 20.29 5.7 21 8.12 21C16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56c.84-.6 1.56-1.36 2.14-2.23"/></svg>' },
];
---

<BaseLayout
  title="Sobre Jueves de Quack — Sopla el Cartucho"
  description="Jueves de Quack — Una iniciativa comunitaria del canal de GitHub en español."
  currentPage="about"
>
  <section class="about-page">
    <h1 class="page-title">
      <span class="title-prefix" aria-hidden="true">►</span> 🦆 JUEVES DE QUACK
    </h1>

    <div class="about-grid">
      <!-- Character card -->
      <div class="char-card pixel-border">
        <div class="char-header">
          <div class="avatar-frame pixel-border">
            <div class="duck-emoji" style="font-size: 4rem; display: flex; align-items: center; justify-content: center; width: 120px; height: 120px;">🦆</div>
          </div>
          <div class="char-meta">
            <h2 class="char-name">JUEVES DE QUACK</h2>
            <dl class="char-stats-list">
              <div class="stat-row">
                <dt>CANAL</dt>
                <dd>GITHUB</dd>
              </div>
              <div class="stat-row">
                <dt>DÍA</dt>
                <dd>CADA JUEVES</dd>
              </div>
              <div class="stat-row">
                <dt>IDIOMA</dt>
                <dd>ESPAÑOL</dd>
              </div>
            </dl>
          </div>
        </div>

        <p class="char-bio">
          Jueves de Quack es una iniciativa comunitaria donde compartimos y aprendemos sobre las últimas
          herramientas de GitHub todos los jueves. Un espacio semanal donde la comunidad se reúne para
          explorar nuevas características, compartir tips y trucos, y conectar con otros desarrolladores
          de la comunidad tecnológica hispana.
        </p>

        <!-- Skills bars -->
        <div class="skills-section">
          <h3 class="skills-title">⚔ STATS</h3>
          {features.map((s) => (
            <div class="skill-row">
              <span class="skill-label">{s.name}</span>
              <div class="skill-track" title={`${s.value}%`}>
                <div class="skill-fill" style={`width:${s.value}%`} />
              </div>
            </div>
          ))}
        </div>

        <!-- Social links -->
        <div class="social-links">
          {socials.map((s) => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" class="social-btn pixel-border" title={s.label}>
              <Fragment set:html={s.svg} />
              <span>{s.label}</span>
            </a>
          ))}
        </div>
      </div>

      <!-- Description panel -->
      <div class="desc-panel pixel-border">
        <h3 class="desc-title">📖 QUEST LOG</h3>
        <div class="desc-entries">
          <div class="desc-entry">
            <span class="desc-marker" aria-hidden="true">▸</span>
            <p>Explorar nuevas características de GitHub</p>
          </div>
          <div class="desc-entry">
            <span class="desc-marker" aria-hidden="true">▸</span>
            <p>Compartir tips y trucos de desarrollo</p>
          </div>
          <div class="desc-entry">
            <span class="desc-marker" aria-hidden="true">▸</span>
            <p>Aprender sobre las mejores prácticas de desarrollo colaborativo</p>
          </div>
          <div class="desc-entry">
            <span class="desc-marker" aria-hidden="true">▸</span>
            <p>Conectar con otros desarrolladores de la comunidad hispana</p>
          </div>
          <div class="desc-entry">
            <span class="desc-marker" aria-hidden="true">▸</span>
            <p>Fortalecer la comunidad tecnológica de habla hispana</p>
          </div>
        </div>

        <h3 class="desc-title" style="margin-top:1rem">🔧 HERRAMIENTAS</h3>
        <div class="desc-entries">
          <div class="desc-entry">
            <span class="desc-marker" aria-hidden="true">★</span>
            <p>GitHub Copilot</p>
          </div>
          <div class="desc-entry">
            <span class="desc-marker" aria-hidden="true">★</span>
            <p>GitHub Actions</p>
          </div>
          <div class="desc-entry">
            <span class="desc-marker" aria-hidden="true">★</span>
            <p>GitHub Codespaces</p>
          </div>
          <div class="desc-entry">
            <span class="desc-marker" aria-hidden="true">★</span>
            <p>GitHub Advanced Security</p>
          </div>
          <div class="desc-entry">
            <span class="desc-marker" aria-hidden="true">★</span>
            <p>GitHub Projects</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 24px 16px 48px;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: 1rem;
    color: #f5d060;
    text-shadow: 2px 2px 0 rgba(0,0,0,0.5);
    margin-bottom: 24px;
  }
  .title-prefix { color: #4ac84a; margin-right: 8px; }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 768px) {
    .about-grid { grid-template-columns: 1fr 1fr; }
  }

  .pixel-border {
    border: 3px solid var(--border-strong, #3a3a3a);
    box-shadow: 4px 4px 0 rgba(0,0,0,0.4), inset 0 0 0 1px rgba(255,255,255,0.05);
  }

  .char-card {
    background: linear-gradient(180deg, #1a2640 0%, #0e1525 100%);
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .char-header { display: flex; gap: 12px; align-items: flex-start; }

  .avatar-frame {
    width: 124px; height: 124px; flex-shrink: 0;
    background: #060e1e;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .avatar-img {
    width: 120px; height: 120px; object-fit: cover;
    image-rendering: auto;
  }

  .char-meta { flex: 1; }
  .char-name {
    margin: 0 0 8px;
    font-family: var(--font-display);
    font-size: 0.6rem;
    color: #f5d060;
    text-shadow: 1px 1px 0 rgba(0,0,0,0.6);
  }
  .char-stats-list { margin: 0; padding: 0; }
  .stat-row {
    display: flex; gap: 6px; font-size: 0.78rem; line-height: 1.6;
    font-family: var(--font-body);
  }
  .stat-row dt { color: #6a8aaa; min-width: 50px; }
  .stat-row dd { color: #a8c8e8; margin: 0; }

  .char-bio {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: #8aa8c8;
    line-height: 1.45;
    margin: 0;
  }

  .skills-section { margin-top: 8px; }
  .skills-title {
    font-family: var(--font-display);
    font-size: 0.5rem;
    color: #4ac84a;
    margin: 0 0 8px;
  }
  .skill-row {
    display: flex; align-items: center; gap: 8px;
    margin-bottom: 6px;
  }
  .skill-label {
    font-family: var(--font-display);
    font-size: 0.42rem;
    color: #a8c8e8;
    width: 80px; text-align: right;
  }
  .skill-track {
    flex: 1; height: 10px;
    background: #0a1520;
    border: 1px solid #1e3a50;
  }
  .skill-fill {
    height: 100%;
    background: linear-gradient(90deg, #1e6e3a, #4ac84a);
    image-rendering: pixelated;
  }

  .social-links {
    display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px;
  }
  .social-btn {
    display: inline-flex; align-items: center; gap: 6px;
    background: linear-gradient(180deg, #22375e, #152040);
    padding: 6px 12px;
    color: #a8c8e8;
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 0.4rem;
    transition: background 0.2s;
  }
  .social-btn:hover { background: linear-gradient(180deg, #2e4880, #1e3060); color: #f5d060; }

  .desc-panel {
    background: linear-gradient(180deg, #1a2640 0%, #0e1525 100%);
    padding: 16px;
  }
  .desc-title {
    font-family: var(--font-display);
    font-size: 0.5rem;
    color: #f5d060;
    margin: 0 0 12px;
  }
  .desc-entries { display: flex; flex-direction: column; gap: 6px; }
  .desc-entry {
    display: flex; gap: 8px; align-items: flex-start;
  }
  .desc-marker { color: #4ac84a; font-size: 0.75rem; flex-shrink: 0; }
  .desc-entry p {
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: #8aa8c8;
    line-height: 1.4;
  }
</style>
