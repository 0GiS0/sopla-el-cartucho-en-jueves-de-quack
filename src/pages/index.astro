---
import BaseLayout from '../layouts/BaseLayout.astro';
import CartridgeCard from '../components/CartridgeCard.astro';
import Console from '../components/Console.astro';
import { sessionsWithAssets, show } from '../lib/talks';

// All sessions are episodes
const sessions = sessionsWithAssets;

// Hero session shown in the console monitor
const heroSession = sessions[0];
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const rawHeroAvatar = heroSession?.assets?.avatar8bit ?? heroSession?.thumbnailUrl ?? '/placeholders/avatar.svg';
const heroAvatar = rawHeroAvatar.startsWith('/') ? `${base}${rawHeroAvatar}` : rawHeroAvatar;

// Card rows
const firstRow = sessions.slice(0, 3);
const remainingSessions = sessions.slice(3);
---

<BaseLayout
  title={`${show.name} — Sopla el Cartucho`}
  description={`${show.name} — Sesiones del canal de ${show.channel} en español.`}
  currentPage="home"
>
  <!-- Hero: console (left) | title + first card row (right) -->
  <section class="hero" id="home" aria-labelledby="site-title">
    <div class="hero-left">
      <Console avatarSrc={heroAvatar} name={heroSession?.speakers?.[0]?.name ?? heroSession?.title} />
    </div>

    <div class="hero-right">
      <div class="hero-title-row">
        <div class="hero-title">
          <h1 id="site-title">Sopla el cartucho</h1>
          <p class="event-name">🦆 {show.name}</p>
        </div>
      </div>

      <div class="hero-cards" id="speakers">
        {firstRow.map((session) => (
          <CartridgeCard session={session} />
        ))}
      </div>
    </div>
  </section>

  <!-- Remaining session rows -->
  <section class="speakers-panel" aria-label="Más sesiones">
    <div class="cartridge-grid">
      {remainingSessions.map((session) => (
        <CartridgeCard session={session} />
      ))}
    </div>
  </section>

  <script>
    // Interactive console: click cartridge → thumbnail in Console; Start → opens YouTube
    document.addEventListener('DOMContentLoaded', () => {
      const screen = document.getElementById('gameboy-screen') as HTMLImageElement;
      const cartridges = document.querySelectorAll('.card-wrap[data-talk-id]');
      const display = document.querySelector('.display') as HTMLElement;
      const startBtn = document.getElementById('gameboy-start');
      
      if (!screen || cartridges.length === 0 || !display) return;

      let selectedVideoUrl: string | null = null;

      // Create GAME OVER overlay
      const gameOverOverlay = document.createElement('div');
      gameOverOverlay.className = 'game-over-overlay';
      gameOverOverlay.innerHTML = `
        <div class="game-over-text">GAME</div>
        <div class="game-over-text">OVER</div>
        <div class="game-over-hint">INSERT CARTRIDGE</div>
      `;
      display.appendChild(gameOverOverlay);

      // Shared AudioContext
      let sharedAudioCtx: AudioContext | null = null;

      function getAudioContext(): AudioContext | null {
        if (!sharedAudioCtx) {
          try {
            sharedAudioCtx = new (window.AudioContext || (window as any).webkitAudioContext)();
          } catch (_) {
            return null;
          }
        }
        return sharedAudioCtx;
      }

      document.addEventListener('click', function unlockAudio() {
        const ctx = getAudioContext();
        if (ctx && ctx.state === 'suspended') ctx.resume();
        document.removeEventListener('click', unlockAudio, true);
      }, true);

      function playGameOverSound() {
        const audioCtx = getAudioContext();
        if (!audioCtx || audioCtx.state !== 'running') return;

        const notes = [523, 392, 330, 262];
        const duration = 0.2;
        
        notes.forEach((freq, i) => {
          const osc = audioCtx.createOscillator();
          const gain = audioCtx.createGain();
          osc.type = 'square';
          osc.frequency.value = freq;
          osc.connect(gain);
          gain.connect(audioCtx.destination);
          const startTime = audioCtx.currentTime + (i * duration);
          gain.gain.setValueAtTime(0.1, startTime);
          gain.gain.exponentialRampToValueAtTime(0.01, startTime + duration);
          osc.start(startTime);
          osc.stop(startTime + duration);
        });
      }

      function playInsertSound() {
        const audioCtx = getAudioContext();
        if (!audioCtx) return;

        const play = () => {
          const notes = [262, 330, 392, 523];
          const duration = 0.1;
          notes.forEach((freq, i) => {
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.type = 'square';
            osc.frequency.value = freq;
            osc.connect(gain);
            gain.connect(audioCtx.destination);
            const startTime = audioCtx.currentTime + (i * duration);
            gain.gain.setValueAtTime(0.08, startTime);
            gain.gain.exponentialRampToValueAtTime(0.01, startTime + duration);
            osc.start(startTime);
            osc.stop(startTime + duration);
          });
        };

        if (audioCtx.state === 'suspended') {
          audioCtx.resume().then(play);
        } else {
          play();
        }
      }

      function showGameOver() {
        gameOverOverlay.classList.add('visible');
        screen.style.opacity = '0.2';
        playGameOverSound();
      }

      function hideGameOver() {
        gameOverOverlay.classList.remove('visible');
        screen.style.opacity = '1';
      }

      // Select a cartridge and update Console screen
      function selectCartridge(card: HTMLElement, playSound = true) {
        hideGameOver();
        cartridges.forEach(c => c.classList.remove('is-selected'));
        card.classList.add('is-selected');
        
        const avatar = card.getAttribute('data-avatar');
        const speaker = card.getAttribute('data-speaker');
        selectedVideoUrl = card.getAttribute('data-video-url');
        
        if (avatar && screen) {
          screen.style.opacity = '0';
          setTimeout(() => {
            screen.src = avatar;
            screen.alt = speaker || '';
            screen.style.opacity = '1';
            if (playSound) playInsertSound();
          }, 150);
        }

        if (window.innerWidth <= 1024 && display) {
          display.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } else {
          card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      }

      // Click on cartridge → load in console
      cartridges.forEach(card => {
        card.addEventListener('click', () => {
          selectCartridge(card as HTMLElement, true);
        });
        (card as HTMLElement).style.cursor = 'pointer';
      });

      // START button → open YouTube video
      if (startBtn) {
        startBtn.style.cursor = 'pointer';
        startBtn.addEventListener('click', () => {
          if (selectedVideoUrl) {
            window.open(selectedVideoUrl, '_blank');
          }
        });
      }

      // Auto-select the first cartridge
      const firstCard = cartridges[0] as HTMLElement;
      if (firstCard) {
        selectCartridge(firstCard, false);
      } else {
        setTimeout(() => showGameOver(), 4000);
      }
    });
  </script>
</BaseLayout>
