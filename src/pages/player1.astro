---
import BaseLayout from '../layouts/BaseLayout.astro';

const skills = [
  { name: 'AI', value: 80 },
  { name: 'CLOUD', value: 90 },
  { name: 'DEVOPS', value: 85 },
  { name: 'CODE', value: 90 },
  { name: 'YOUTUBE', value: 95 },
];

const socials = [
  {
    label: 'BLOG',
    href: 'https://www.returngis.net/',
    svg: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10s10-4.48 10-10S17.52 2 12 2m-1 17.93c-3.95-.49-7-3.85-7-7.93c0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41c0 2.08-.8 3.97-2.1 5.39"/></svg>',
  },
  {
    label: 'YOUTUBE',
    href: 'https://youtube.com/@returngis',
    svg: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><path fill="currentColor" d="m10 15l5.19-3L10 9zm11.56-7.83c.13.47.22 1.1.28 1.9c.07.8.1 1.49.1 2.09L22 12c0 2.19-.16 3.8-.44 4.83c-.25.9-.83 1.48-1.73 1.73c-.47.13-1.33.22-2.65.28c-1.3.07-2.49.1-3.59.1L12 19c-4.19 0-6.8-.16-7.83-.44c-.9-.25-1.48-.83-1.73-1.73c-.13-.47-.22-1.1-.28-1.9c-.07-.8-.1-1.49-.1-2.09L2 12c0-2.19.16-3.8.44-4.83c.25-.9.83-1.48 1.73-1.73c.47-.13 1.33-.22 2.65-.28c1.3-.07 2.49-.1 3.59-.1L12 5c4.19 0 6.8.16 7.83.44c.9.25 1.48.83 1.73 1.73"/></svg>',
  },
  {
    label: 'GITHUB',
    href: 'https://github.com/0GiS0',
    svg: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2"/></svg>',
  },
  {
    label: 'X',
    href: 'https://x.com/0GiS0',
    svg: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><path fill="currentColor" d="M22.46 6c-.77.35-1.6.58-2.46.69c.88-.53 1.56-1.37 1.88-2.38c-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29c0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15c0 1.49.75 2.81 1.91 3.56c-.71 0-1.37-.2-1.95-.5v.03c0 2.08 1.48 3.82 3.44 4.21a4.2 4.2 0 0 1-1.93.07a4.28 4.28 0 0 0 4 2.98a8.52 8.52 0 0 1-5.33 1.84q-.51 0-1.02-.06C3.44 20.29 5.7 21 8.12 21C16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56c.84-.6 1.56-1.36 2.14-2.23"/></svg>',
  },
  {
    label: 'LINKEDIN',
    href: 'https://www.linkedin.com/in/giselatorresbuitrago/',
    svg: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><path fill="currentColor" d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2zm-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.3v-1.11h-2.79v8.37h2.79v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93zM6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37z"/></svg>',
  },
];
---

<BaseLayout
  title="PLAYER 1 — Gisela Torres"
  description="Gisela Torres — Global Blackbelt en Microsoft, Docker Captain y creadora de Jueves de Quack."
  currentPage="player1"
>
  <section class="player1-page">
    <h1 class="page-title">
      <span class="title-prefix blink" aria-hidden="true">▶</span> PLAYER 1
    </h1>

    <div class="player-grid">
      <!-- Character card -->
      <div class="char-card pixel-border">
        <div class="char-header">
          <div class="avatar-frame pixel-border">
            <img
              src="https://avatars.githubusercontent.com/u/175379"
              alt="Gisela Torres"
              class="avatar-img"
              width="120"
              height="120"
            />
          </div>
          <div class="char-meta">
            <h2 class="char-name">GISELA TORRES</h2>
            <dl class="char-stats-list">
              <div class="stat-row">
                <dt>CLASS</dt>
                <dd>GLOBAL BLACKBELT</dd>
              </div>
              <div class="stat-row">
                <dt>GUILD</dt>
                <dd>MICROSOFT</dd>
              </div>
              <div class="stat-row">
                <dt>ALIAS</dt>
                <dd>0GiS0</dd>
              </div>
            </dl>
          </div>
        </div>

        <p class="char-bio">
          Apasionada de la tecnología, la inteligencia artificial y el desarrollo de software.
          Comparte conocimientos a través de su canal de YouTube ReturnGis y su blog returngis.net.
          Fue Microsoft MVP antes de unirse a Microsoft y actualmente es Docker Captain.
        </p>

        <div class="skills-section">
          <h3 class="skills-title">⚔ SKILLS</h3>
          {
            skills.map((s) => (
              <div class="skill-row">
                <span class="skill-label">{s.name}</span>
                <div class="skill-track" title={`${s.value}%`}>
                  <div class="skill-fill" style={`width:${s.value}%`} />
                </div>
              </div>
            ))
          }
        </div>

        <div class="social-links">
          {
            socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                class="social-btn pixel-border"
                title={s.label}
              >
                <Fragment set:html={s.svg} />
                <span>{s.label}</span>
              </a>
            ))
          }
        </div>
      </div>

      <!-- Quest + Connect panel -->
      <div class="info-panel pixel-border">
        <h3 class="panel-title">🎮 CURRENT QUEST</h3>
        <div class="quest-box pixel-border">
          <p class="quest-name">Jueves de Quack</p>
          <p class="quest-desc">
            Sesiones semanales en directo en el canal de GitHub en español donde exploramos las
            últimas herramientas de GitHub, compartimos tips y conectamos con la comunidad hispana
            de desarrolladores.
          </p>
        </div>

        <h3 class="panel-title" style="margin-top:1.5rem">📡 CONNECT</h3>
        <div class="connect-grid">
          {
            socials.map((s) => (
              <a
                href={s.href}
                target="_blank"
                rel="noopener noreferrer"
                class="connect-link pixel-border"
              >
                <Fragment set:html={s.svg} />
                <span>{s.label}</span>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .player1-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 24px 16px 48px;
  }

  .page-title {
    font-family: var(--font-display);
    font-size: 1rem;
    color: #4ac84a;
    text-shadow: 2px 2px 0 rgba(0, 0, 0, 0.5);
    margin-bottom: 24px;
  }

  .title-prefix {
    margin-right: 8px;
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }
  .blink {
    display: inline-block;
    animation: blink 1s step-start infinite;
  }

  .player-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 768px) {
    .player-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .pixel-border {
    border: 3px solid var(--border-strong, #3a3a3a);
    box-shadow:
      4px 4px 0 rgba(0, 0, 0, 0.4),
      inset 0 0 0 1px rgba(255, 255, 255, 0.05);
  }

  /* Character card */
  .char-card {
    background: linear-gradient(180deg, #1a2640 0%, #0e1525 100%);
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .char-header {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }

  .avatar-frame {
    width: 124px;
    height: 124px;
    flex-shrink: 0;
    background: #060e1e;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .avatar-img {
    width: 120px;
    height: 120px;
    object-fit: cover;
  }

  .char-meta {
    flex: 1;
  }

  .char-name {
    margin: 0 0 8px;
    font-family: var(--font-display);
    font-size: 0.6rem;
    color: #f5d060;
    text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.6);
  }

  .char-stats-list {
    margin: 0;
    padding: 0;
  }

  .stat-row {
    display: flex;
    gap: 6px;
    font-size: 0.78rem;
    line-height: 1.6;
    font-family: var(--font-body);
  }

  .stat-row dt {
    color: #6a8aaa;
    min-width: 50px;
  }

  .stat-row dd {
    color: #a8c8e8;
    margin: 0;
  }

  .char-bio {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: #8aa8c8;
    line-height: 1.45;
    margin: 0;
  }

  /* Skills */
  .skills-section {
    margin-top: 4px;
  }

  .skills-title {
    font-family: var(--font-display);
    font-size: 0.5rem;
    color: #4ac84a;
    margin: 0 0 8px;
  }

  .skill-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 6px;
  }

  .skill-label {
    font-family: var(--font-display);
    font-size: 0.42rem;
    color: #a8c8e8;
    width: 80px;
    text-align: right;
  }

  .skill-track {
    flex: 1;
    height: 10px;
    background: #0a1520;
    border: 1px solid #1e3a50;
  }

  .skill-fill {
    height: 100%;
    background: linear-gradient(90deg, #1e6e3a, #4ac84a);
    image-rendering: pixelated;
  }

  /* Social */
  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: linear-gradient(180deg, #22375e, #152040);
    padding: 6px 12px;
    color: #a8c8e8;
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 0.4rem;
    transition: background 0.2s;
  }

  .social-btn:hover {
    background: linear-gradient(180deg, #2e4880, #1e3060);
    color: #f5d060;
  }

  /* Info panel */
  .info-panel {
    background: linear-gradient(180deg, #1a2640 0%, #0e1525 100%);
    padding: 16px;
  }

  .panel-title {
    font-family: var(--font-display);
    font-size: 0.5rem;
    color: #f5d060;
    margin: 0 0 12px;
  }

  .quest-box {
    background: #060e1e;
    padding: 12px 16px;
    margin-bottom: 8px;
  }

  .quest-name {
    font-family: var(--font-display);
    font-size: 0.55rem;
    color: #f5d060;
    margin: 0 0 8px;
  }

  .quest-desc {
    font-family: var(--font-body);
    font-size: 0.82rem;
    color: #8aa8c8;
    line-height: 1.45;
    margin: 0;
  }

  .connect-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .connect-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: linear-gradient(180deg, #22375e, #152040);
    padding: 6px 12px;
    color: #a8c8e8;
    text-decoration: none;
    font-family: var(--font-display);
    font-size: 0.4rem;
    transition: background 0.2s;
  }

  .connect-link:hover {
    background: linear-gradient(180deg, #2e4880, #1e3060);
    color: #f5d060;
  }
</style>
